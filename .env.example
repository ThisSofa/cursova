# Container names
DB_CONTAINER_NAME=inventory_db
API_CONTAINER_NAME=inventory_api
WEB_CONTAINER_NAME=inventory_web

# Exposed ports
API_PORT=8000
WEB_PORT=8080

# Database credentials
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=inventory
MYSQL_USER=inventory_user
MYSQL_PASSWORD=change_me_user

# Service URLs
DATABASE_URL=mysql+pymysql://inventory_user:change_me_user@db:3306/inventory
API_BASE_URL=http://api:8000
